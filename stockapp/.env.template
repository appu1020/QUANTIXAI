# QuantaView — Environment Variables Template
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─── Django Core ─────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── News API (free tier available at https://newsdata.io) ───
NEWSDATA_API_KEY=

# ─── Reddit API (optional — for Reddit sentiment analysis) ───
# Create an app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=QuantaView/1.0

# ─── LLM API (optional — for enhanced RAG responses) ─────────
# Supports Google Gemini or OpenAI-compatible keys
LLM_API_KEY=
