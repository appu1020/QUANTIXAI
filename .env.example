# QuantixAI Environment Variables
# Copy this to .env and configure the values for your deployment

# Django Settings
SECRET_KEY=replace-this-with-a-very-long-secret-key-for-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,.hf.space
CSRF_TRUSTED_ORIGINS=https://*.hf.space

# External APIs
NEWSDATA_API_KEY=your_newsdata_api_key_here
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=QuantixAI/1.0
LLM_API_KEY=your_llm_api_key_here

# Gunicorn Settings (Optional - Hugging Face standard port is 7860)
PORT=7860
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=120
